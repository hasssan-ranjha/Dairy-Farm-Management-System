<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<ScrollPane fitToWidth="true" style="-fx-background-color: transparent;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="FarmManagement.AddCowController">
    <VBox spacing="15.0">
        <padding>
            <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
        </padding>

        <Label style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Register New Cow" />
        <Separator />

        <GridPane hgap="15.0" vgap="12.0">
            <columnConstraints>
                <ColumnConstraints minWidth="120.0" prefWidth="150.0" />
                <ColumnConstraints hgrow="ALWAYS" />
            </columnConstraints>

            <Label text="Cow ID:" GridPane.rowIndex="0" />
            <TextField fx:id="txtId" promptText="Enter Unique ID" GridPane.columnIndex="1" GridPane.rowIndex="0" />

            <Label text="Breed:" GridPane.rowIndex="1" />
            <ComboBox fx:id="comboBreed" prefWidth="300.0" GridPane.columnIndex="1" GridPane.rowIndex="1" />

            <Label text="Source / Farm:" GridPane.rowIndex="2" />
            <TextField fx:id="txtSource" promptText="e.g. Ranjha Farm" GridPane.columnIndex="1" GridPane.rowIndex="2" />

            <Label text="Purchase Price:" GridPane.rowIndex="3" />
            <TextField fx:id="txtPrice" promptText="Enter amount in PKR" GridPane.columnIndex="1" GridPane.rowIndex="3" />

            <Label text="Entry Date:" GridPane.rowIndex="4" />
            <DatePicker fx:id="dateEntry" prefWidth="300.0" GridPane.columnIndex="1" GridPane.rowIndex="4" />

            <Label text="Repro Status:" GridPane.rowIndex="5" />
            <ComboBox fx:id="comboRepro" prefWidth="300.0" GridPane.columnIndex="1" GridPane.rowIndex="5" />
        </GridPane>

        <VBox fx:id="breedingSection" spacing="12.0" style="-fx-background-color: #f8f9fa; -fx-padding: 15; -fx-border-color: #dee2e6; -fx-border-radius: 5;">
            <Label style="-fx-font-weight: bold;" text="Breeding Details" />
            <GridPane hgap="15.0" vgap="12.0">
                <columnConstraints>
                    <ColumnConstraints minWidth="120.0" prefWidth="135.0" />
                    <ColumnConstraints hgrow="ALWAYS" />
                </columnConstraints>

                <Label text="Insemination Date:" GridPane.rowIndex="0" />
                <DatePicker fx:id="dateInsem" prefWidth="300.0" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                <Label text="Semen Type:" GridPane.rowIndex="1" />
                <ComboBox fx:id="comboSemenType" prefWidth="300.0" GridPane.columnIndex="1" GridPane.rowIndex="1" />

                <Label text="Semen Name:" GridPane.rowIndex="2" />
                <TextField fx:id="txtSemenName" promptText="Enter Semen ID/Name" GridPane.columnIndex="1" GridPane.rowIndex="2" />
            </GridPane>
        </VBox>

        <Separator />
        <Button onAction="#handleSave" prefHeight="40.0" prefWidth="200.0" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;" text="CONFIRM &amp; SAVE" />
    </VBox>
</ScrollPane>