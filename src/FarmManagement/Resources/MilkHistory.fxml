<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20.0" style="-fx-background-color: white;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="FarmManagement.MilkHistoryController">
    <padding>
        <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="20.0">
        <Label fx:id="lblCowId" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" text="Milk History" />
        <Region HBox.hgrow="ALWAYS" />
        <VBox alignment="CENTER_RIGHT">
            <Label fx:id="lblAverage" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #27ae60;" text="Average: 0.0 L" />
            <Label fx:id="lblTotal" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #2980b9;" text="Total: 0.0 L" />
        </VBox>
    </HBox>
    <Separator />

    <TableView fx:id="tableMilk" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colDate" prefWidth="200.0" text="Date" />
            <TableColumn fx:id="colLiters" prefWidth="200.0" text="Liters Produced" />
        </columns>
    </TableView>

    <Button onAction="#handleBack" style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-font-weight: bold;" text="← BACK TO INVENTORY" />
</VBox>